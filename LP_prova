            maior = f_notas[a]
            pos_maior = a
        if menor > f_notas[a]:
            menor = f_notas[a]
            pos_menor =a
    return pos_maior, pos_menor

# 06 contagem de letras e trasformação para o perceitual
def cal_percentual (f_mencao):
    cont= 0
    percentual = []
    cont_ss =0
    cont_ms =0
    cont_mm =0
    cont_mi =0
    cont_ii =0
    for a in range(len(f_mencao)):
        cont= cont+ 1
        if f_mencao[a] == 'SS':
            cont_ss = cont_ss + 1
        elif f_mencao[a] == 'MS':
            cont_ms = cont_ms + 1
        elif f_mencao[a] == 'MM':
            cont_mm = cont_mm + 1
        elif f_mencao[a] == 'MI':
            cont_mi = cont_mi + 1
        elif f_mencao[a] == 'II':
            cont_ii = cont_ii + 1
    percentual.append(round((cont_ss/cont)*100,2))
    percentual.append(round((cont_ms/cont)*100,2))
    percentual.append(round((cont_mm/cont)*100,2))
    percentual.append(round((cont_mi/cont)*100,2))
    percentual.append(round((cont_ii/cont)*100,2))
    return percentual

