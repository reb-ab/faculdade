# 01 médias das notas em uma lista (separado por aluno)
def cal_notas (f_notas):
    media_al = []
    total = 0
    for a in range(len(f_notas)):
        nota_interna = f_notas[a]
        for b in range(len(nota_interna)):
            total = (total + nota_interna[b])
        add = round((total/2), 2)
        media_al.append(add)
        total =0
    return media_al

# 02 converter para (SS MS MM MI II) e adcionar para a lista
def cal_mencao(f_notas):
    mencao = []
    for a in range(len(f_notas)):
        if f_notas[a] >= 9:
            mencao.append('SS')
        elif 7 <= f_notas[a] < 9:
            mencao.append('MS')
        elif 5 <= f_notas[a] < 7:
            mencao.append('MM')
        elif 2.5 <= f_notas[a] < 5:
            mencao.append('MI')
        elif 0 <= f_notas[a] < 2.5:
            mencao.append('II')
    return mencao

# 03 somatorio das notas e um contador para dividir = media da turma      
def cal_media_turma(f_notas):
    media_turma = 0
    soma = 0 
    contador = 0
    for a in range(len(f_notas)):
        contador = contador + 1 
        soma = soma + f_notas[a]
    media_turma = round((soma/contador),2)
    return media_turma

# 05 buscar maior e menor aluno (MAIOR MENOR) e passar o seu local
